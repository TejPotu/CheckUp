# === Google Gemini ===
# GOOGLE_API_KEY=your-google-api-key

# === Meta WhatsApp Cloud API ===
META_WHATSAPP_TOKEN=your-meta-access-token
META_PHONE_NUMBER_ID=your-phone-number-id
META_VERIFY_TOKEN=your-webhook-verify-token
META_APP_SECRET=your-app-secret

# === PostgreSQL ===
DATABASE_URL=postgresql+asyncpg://checkup:checkup@localhost:5432/checkup

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Qdrant ===
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=elderly_health

# === App Settings ===
APP_ENV=development
LOG_LEVEL=INFO
DEFAULT_LANGUAGE=te
CHECKIN_TIME=09:00
TIMEZONE=Asia/Kolkata
